# Copy to .env and fill in values.
DISCORD_TOKEN=

# Used when a guild doesn't have settings yet.
# Use an IANA timezone name (works on Windows when tzdata is installed).
DEFAULT_TIMEZONE=America/Chicago

# 0=Mon .. 6=Sun
DEFAULT_WEEK_START=0

# Optional: speeds up slash-command registration during development
# by syncing commands to a single guild (server).
DEV_GUILD_ID=

# One-time cleanup: set to your server's guild ID to remove duplicate guild commands.
# Remove this variable after deploying once.
# CLEAR_GUILD_COMMANDS_ID=

# Preferred for production hosting (Supabase/Postgres):
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
#
# If DATABASE_URL is set, it is used instead of DB_PATH.
DATABASE_URL=

# SQLite file path (relative or absolute) — used for local development.
DB_PATH=./data/time_tracker.sqlite3
